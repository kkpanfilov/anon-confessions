generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Confession {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(32)
  content   String   @db.Text
  likes     Int      @default(0)
  tokenHash String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  likedBy   ConfessionLike[]

  @@index([createdAt(sort: Desc)])
  @@index([likes(sort: Desc)])
}

model ConfessionLike {
  id           String     @id @default(uuid()) @db.Uuid
  confessionId String     @db.Uuid
  voterHash    String     @db.VarChar(64)
  createdAt    DateTime   @default(now()) @map("created_at")

  confession   Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)

  @@unique([confessionId, voterHash])
  @@index([confessionId])
}

