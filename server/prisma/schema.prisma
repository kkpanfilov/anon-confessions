generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Confession {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(32)
  content   String   @db.Text
  // TODO: Сделать API строго идемпотентным: db-check: likes >= 0 + пофиксить ранний выход при unlike и likes === 0
  /**
   * /**
   * /*
   * unlike делает ранний выход при likes === 0, не проверяя фактическую запись в ConfessionLike: confessions.controller.js (line 321).
   * Если счетчик уже разъехался, операция не “лечит” данные.
   */
  likes     Int      @default(0)
  tokenHash String   @unique
  randomKey Float    @default(dbgenerated("random()")) @map("random_key")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  likedBy ConfessionLike[]

  @check([likes >= 0], name: "likes_not_negative")
  @@index([randomKey])
  @@index([createdAt(sort: Desc)])
  @@index([likes(sort: Desc)])
}

model ConfessionLike {
  id           String   @id @default(uuid()) @db.Uuid
  confessionId String   @db.Uuid
  voterHash    String   @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")

  confession Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)

  @@unique([confessionId, voterHash])
  @@index([confessionId])
}
